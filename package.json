{
  "name": "dinkdonkbot",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "description": "A discord bot that posts notifications when twitch streamers go live",
  "author": "Matthew Trotman <savageguy@gmail.com>",
  "license": "MIT",
  "keywords": [],
  "main": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "wrangler dev src/server.ts --test-scheduled",
    "localtunnel": "npx localtunnel --port 8787 --subdomain dinkdonkbotdev",
    "ngrok": "npx ngrok http 8787",
    "fix": "eslint --fix .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "register": "tsx src/discord/register.ts",
    "publish": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrations": "wrangler d1 migrations apply DB --remote",
    "db:migrations-local": "wrangler d1 migrations apply DB"
  },
  "dependencies": {
    "@discordjs/formatters": "0.6.2",
    "@discordjs/rest": "2.6.3",
    "date-fns-tz": "3.2.0",
    "discord-api-types": "0.38.50",
    "discord-interactions": "4.4.0",
    "drizzle-orm": "0.45.2",
    "itty-router": "5.0.24",
    "tz-lookup": "6.1.25"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260721.1",
    "@types/node": "25.9.5",
    "@types/tz-lookup": "6.1.2",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "10.3.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5",
    "wrangler": "4.112.0"
  }
}
